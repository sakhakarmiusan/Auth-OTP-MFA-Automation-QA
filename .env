# Secure Auth App Configuration

# The port the server will run on
PORT=3000

# Session secret (must be a random string in production)
SESSION_SECRET=super_secret_session_key_for_testing

# Nodemailer setup for Gmail
# To use Gmail, you MUST use an "App Password", not your normal password.
# 1. Turn on 2-Step Verification for your Google Account.
# 2. Go to Security -> 2-Step Verification -> App passwords.
# 3. Create a new app password and paste it here.
EMAIL_SERVICE=outlook
EMAIL_USER=usan.sakhakarmi@vairavtech.com
EMAIL_PASS=B@B@zz88